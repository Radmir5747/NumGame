<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chalkboard"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/trainBtn"
        style="@style/paperButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/train"
        android:text="@string/train_btn"
        app:layout_constraintBottom_toTopOf="@+id/convertBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideline"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <Button
        android:id="@+id/convertBtn"
        style="@style/paperButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/convert"
        android:text="@string/convert_btn"
        app:layout_constraintBottom_toTopOf="@+id/docsBtn"
        app:layout_constraintEnd_toEndOf="@+id/trainBtn"
        app:layout_constraintStart_toStartOf="@+id/trainBtn"
        app:layout_constraintTop_toBottomOf="@+id/trainBtn"
        app:layout_constraintVertical_bias="0.5" />

    <Button
        android:id="@+id/docsBtn"
        style="@style/paperButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/book"
        android:text="@string/docs_btn"
        app:layout_constraintBottom_toTopOf="@+id/statsBtn"
        app:layout_constraintEnd_toEndOf="@+id/convertBtn"
        app:layout_constraintStart_toStartOf="@+id/convertBtn"
        app:layout_constraintTop_toBottomOf="@+id/convertBtn"
        app:layout_constraintVertical_bias="0.5" />

    <Button
        android:id="@+id/statsBtn"
        style="@style/paperButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/stats"
        android:text="@string/stats_btn"
        app:layout_constraintBottom_toTopOf="@+id/aboutBtn"
        app:layout_constraintEnd_toEndOf="@+id/docsBtn"
        app:layout_constraintStart_toStartOf="@+id/docsBtn"
        app:layout_constraintTop_toBottomOf="@+id/docsBtn"
        app:layout_constraintVertical_bias="0.5" />

    <Button
        android:id="@+id/aboutBtn"
        style="@style/paperButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/info"
        android:text="@string/about_btn"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/statsBtn"
        app:layout_constraintStart_toStartOf="@+id/statsBtn"
        app:layout_constraintTop_toBottomOf="@+id/statsBtn"
        app:layout_constraintVertical_bias="0.5" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="144dp"
        android:layout_height="144dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:srcCompat="@drawable/icon" />

    <TextView
        android:id="@+id/mainscreenTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bad_script"
        android:text="@string/app_name"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/imageView"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />
</androidx.constraintlayout.widget.ConstraintLayout>